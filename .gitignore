# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# ── Django ────────────────────────────────────────────
backend/db.sqlite3
*.log
local_settings.py

# ── Backend data directory (never push to GitHub) ─────
# Everything the backend reads/writes at runtime lives here:
#   backend/data/                  → crawler CSVs + crawl_state.json
#   backend/data/gsc/              → Search Console pull + OAuth files
#   backend/data/aem/              → AEM page-model JSON exports
#   backend/data/_semrush_cache/   → SEMrush response cache
# Mounted as docker volumes in prod; pure per-run artefacts, not source.
backend/data/
backend/reports/

# ── Catch-all safety nets ─────────────────────────────
# Generic JSON config (package.json, tsconfig.json, etc.) stays
# tracked — only data-file extensions and credential filename
# patterns are blanket-excluded.
*.csv
*.xlsx
*.parquet

# OAuth / service-account credentials, regardless of where they land.
client_secret*.json
token.json
*.credentials.json
service-account*.json

# ── Node / Vite ───────────────────────────────────────
node_modules/
frontend/web/dist/
frontend/web/.vite/
*.tsbuildinfo

# ── Env files (commit `.env.example`, never `.env`) ───
.env
.env.local
.env.*.local
!.env.example

# ── IDE / OS ──────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ── Claude Code session cache ─────────────────────────
.claude/
