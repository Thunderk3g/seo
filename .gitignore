# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# ── Django ────────────────────────────────────────────
backend/db.sqlite3
*.log
local_settings.py

# ── Crawler runtime output ────────────────────────────
# File-backed crawler writes CSVs / crawl_state.json to backend/data/
# and XLSX reports to backend/reports/. Mounted as docker volumes;
# they're per-run artifacts, not source.
backend/data/
backend/reports/

# ── Data dumps (never push to GitHub) ─────────────────
# AEM sitemap exports (~100 MB of page-model JSON), GSC pulls,
# experimental notebooks, OAuth client secrets, OAuth tokens, and
# any other raw data scratch directories live here. None of this
# belongs in version control.
sitemap/
test/
gsc_data/

# Catch-all data file patterns. Generic JSON config (package.json,
# tsconfig.json, etc.) stays tracked — only explicit data paths
# above and these extensions are excluded.
*.csv
*.xlsx
*.parquet

# OAuth / service-account credentials, regardless of where they land.
client_secret*.json
token.json
*.credentials.json
service-account*.json

# ── Node / Vite ───────────────────────────────────────
node_modules/
frontend/web/dist/
frontend/web/.vite/
*.tsbuildinfo

# ── Env files (commit `.env.example`, never `.env`) ───
.env
.env.local
.env.*.local
!.env.example

# ── IDE / OS ──────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ── Claude Code session cache ─────────────────────────
.claude/
