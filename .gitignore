# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/
*test.ipynb

# ── Django ────────────────────────────────────────────
backend/db.sqlite3
*.log
local_settings.py

# ── Celery runtime state ──────────────────────────────
backend/celerybeat-schedule
backend/celerybeat-schedule.*

# ── ML model weights (re-downloadable from HuggingFace) ─
backend/models/

# ── Backend data directory (never push to GitHub) ─────
# Everything the backend reads/writes at runtime lives here:
#   backend/data/                  → crawler CSVs + crawl_state.json
#   backend/data/gsc/              → Search Console pull + OAuth files
#   backend/data/aem/              → AEM page-model JSON exports
#   backend/data/_semrush_cache/   → SEMrush response cache
# Mounted as docker volumes in prod; pure per-run artefacts, not source.
backend/data/
backend/reports/

# ── Internal strategy / audit docs (never push to GitHub) ─
# All planning, audit, architecture, and decision docs live in docs/.
# They contain commercially-sensitive analysis: competitor benchmarks,
# pre-deploy security TODOs, leaked-key rotation notes, GSC numbers,
# revenue-implication estimates. Keep local-only.
docs/

# ── Catch-all safety nets ─────────────────────────────
# Generic JSON config (package.json, tsconfig.json, etc.) stays
# tracked — only data-file extensions and credential filename
# patterns are blanket-excluded.
*.csv
*.xlsx
*.parquet

# OAuth / service-account credentials, regardless of where they land.
client_secret*.json
token.json
*.credentials.json
service-account*.json

# ── Node / Vite ───────────────────────────────────────
node_modules/
frontend/web/dist/
frontend/web/.vite/
*.tsbuildinfo

# ── Env files (commit `.env.example`, never `.env`) ───
.env
.env.local
.env.*.local
!.env.example

# ── IDE / OS ──────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ── Claude Code session cache ─────────────────────────
.claude/

# ── Corporate root CAs for Docker build TLS ───────────
# Each dev's network (Bajaj intranet, Cisco Umbrella SIG, home, etc.) has
# different intercepting CAs. Don't ship them — devs export their own from
# Cert:\LocalMachine\Root into backend/certs/*.crt and the Dockerfile folds
# them into the image's system trust bundle before pip install.
backend/certs/*.crt
!backend/certs/.gitkeep

# ── Local-only buy-journey scraper (Playwright form-walker) ───
# Tests the term-plan buy flow end to end up to (but not including)
# the payment step. Output is fake-data-driven and lives entirely
# under this dir — runs/, captured HARs, screenshots, request logs.
# Keep local so we don't ship fake PII or live response captures.
test_script_buy_journey/

# Local DB backups (never commit)
_db_backups/
*.sql

# ── Standalone Claude Code plugin (its OWN git repo — never tracked here) ─
# Cloned/worked-on inside this folder for convenience, but it is an
# independent repository with its own remote and .gitignore. Excluding it
# here prevents the two git repos from clashing.
content-gap-plugin/
# Plugin run outputs (contain real URLs) — never commit to this repo either.
content-gap-runs/
