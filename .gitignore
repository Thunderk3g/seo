node_modules/
frontend/web/dist/
frontend/web/.vite/
*.tsbuildinfo

# ── Env files (commit `.env.example`, never `.env`) ───
.env
.env.local
.env.*.local
!.env.example

# ── IDE / OS ──────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

