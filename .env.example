# ─────────────────────────────────────────────────────────────
# Django Settings
# ─────────────────────────────────────────────────────────────
SECRET_KEY=replace-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# ─────────────────────────────────────────────────────────────
# PostgreSQL Database
# Compose service name is `db`; compose env sets user/password/seo_db.
# ─────────────────────────────────────────────────────────────
DB_NAME=seo_db
DB_USER=user
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://user:password@db:5432/seo_db

# ─────────────────────────────────────────────────────────────
# Celery / Redis
# Compose service name is `redis`.
# ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────
# Anthropic / Lattice AI (Day 5 — IndexingIntelligenceAgent)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LATTICE_AI_MODEL=claude-haiku-4-5-20251001

# ─────────────────────────────────────────────────────────────
# GSC Integration (Future)
# ─────────────────────────────────────────────────────────────
GSC_API_KEY=
