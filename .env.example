# ─────────────────────────────────────────────────────────────
# Django Settings
# ─────────────────────────────────────────────────────────────
SECRET_KEY=replace-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# ─────────────────────────────────────────────────────────────
# PostgreSQL Database
# Compose service name is `db`; compose env sets user/password/seo_db.
# ─────────────────────────────────────────────────────────────
DB_NAME=seo_db
DB_USER=user
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://user:password@db:5432/seo_db

# ─────────────────────────────────────────────────────────────
# Celery / Redis
# Compose service name is `redis`.
# ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────
# LLM Provider (Groq — OpenAI-compatible) used by the grading agents
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.2
# Set to "false" inside the Docker image when behind a corp MITM proxy.
LLM_SSL_VERIFY=

# ─────────────────────────────────────────────────────────────
# SEMrush — competitor + keyword facts
# ─────────────────────────────────────────────────────────────
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=in
SEMRUSH_DEFAULT_LIMIT=100
SEMRUSH_SSL_VERIFY=
SEMRUSH_COMPETITOR_CACHE_TTL=604800

# ─────────────────────────────────────────────────────────────
# Competitor SEO Gap (Phase 1 — SEMrush-driven gap analysis)
# ─────────────────────────────────────────────────────────────
COMPETITOR_ENABLED=true
COMPETITOR_TOP_N=10
COMPETITOR_PAGES_PER_COMP=50
COMPETITOR_KW_PER_COMP=100
COMPETITOR_RATE_LIMIT_SEC=1.0
COMPETITOR_TIMEOUT_SEC=15
COMPETITOR_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
COMPETITOR_CACHE_TTL_SECONDS=604800
COMPETITOR_OUR_PAGES_LIMIT=200
COMPETITOR_SSL_VERIFY=

# ─────────────────────────────────────────────────────────────
# AI Search Visibility — Phase 2 detection layer
# ─────────────────────────────────────────────────────────────
# Probes the AI search layer (ChatGPT / Claude / Gemini / Perplexity /
# Grok) and surfaces brand citation gaps vs competitors. Every key is
# independent — leave any blank to silently skip that provider; the
# rest still run. Disable the whole agent with AI_VISIBILITY_ENABLED=false.
AI_VISIBILITY_ENABLED=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
# Optional model overrides — defaults shown.
OPENAI_AI_VISIBILITY_MODEL=gpt-4o-mini
ANTHROPIC_AI_VISIBILITY_MODEL=claude-3-5-haiku-latest
GOOGLE_AI_VISIBILITY_MODEL=gemini-2.0-flash
PERPLEXITY_AI_VISIBILITY_MODEL=sonar
XAI_AI_VISIBILITY_MODEL=grok-2-latest
AI_VISIBILITY_MAX_QUERIES=20
AI_VISIBILITY_REQUEST_TIMEOUT_SEC=30
AI_VISIBILITY_CACHE_TTL=604800
AI_VISIBILITY_SSL_VERIFY=

# ─────────────────────────────────────────────────────────────
# SERP API — Phase 3 detection layer (SerpAPI primary)
# ─────────────────────────────────────────────────────────────
# Traditional SERP visibility via SerpAPI (Google / Bing / DuckDuckGo).
# Leave SERPAPI_API_KEY blank to silently skip the SERPVisibilityAgent.
SERP_API_ENABLED=true
SERP_API_PROVIDER=serpapi
SERPAPI_API_KEY=
SERP_API_ENGINES=google,bing,duckduckgo
# Comma-separated devices to probe per (query × engine). Each device
# counts as its own billed SerpAPI call, so `desktop,mobile` doubles
# quota usage vs `desktop` alone. Google honours device split; Bing /
# DuckDuckGo return the same shape but rows are still tagged so the UI
# can filter consistently.
SERP_API_DEVICES=desktop,mobile
# Which device feeds the competitor leaderboard / visibility comparison.
# Leave as desktop unless you specifically want mobile-first scoring.
SERP_API_PRIMARY_DEVICE=desktop
SERP_API_COUNTRY=in
SERP_API_LANGUAGE=en
SERP_API_MAX_QUERIES=20
SERP_API_REQUEST_TIMEOUT_SEC=30
SERP_API_CACHE_TTL=604800
SERP_API_SSL_VERIFY=

# ─────────────────────────────────────────────────────────────
# PageSpeed Insights — Core Web Vitals for competitor pages
# ─────────────────────────────────────────────────────────────
# Authenticated via a Google Cloud service account so quota bills
# against our project (default 25k calls/day). PSI accepts any bearer
# token from a project that has the PageSpeed Insights API enabled —
# the SA needs no special IAM role.
# Leave PSI_SERVICE_ACCOUNT_JSON empty (and/or PSI_ENABLED=false) to
# silently skip CWV enrichment.
PSI_ENABLED=true
PSI_SERVICE_ACCOUNT_JSON=backend/data/secrets/psi-sa.json
PSI_STRATEGIES=mobile,desktop
PSI_REQUEST_TIMEOUT_SEC=120
PSI_CACHE_TTL=604800
PSI_MAX_URLS_PER_RUN=100
PSI_SSL_VERIFY=

# ─────────────────────────────────────────────────────────────
# GSC Integration (Future)
# ─────────────────────────────────────────────────────────────
GSC_API_KEY=

# ─────────────────────────────────────────────────────────────
# SEO AI runtime
# ─────────────────────────────────────────────────────────────
SEO_AI_DATA_DIR=
SEO_AI_GSC_DATA_DIR=
SEO_AI_SITEMAP_DIR=
SEO_AI_MAX_FINDINGS_PER_AGENT=20
SEO_AI_BUDGET_USD_PER_RUN=2.00
